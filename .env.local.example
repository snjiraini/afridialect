# =============================================================================
# Afridialect.ai — Environment Variables Template
# =============================================================================
# LOCAL DEVELOPMENT SETUP
# -----------------------
# .env.local needs only the NEXT_PUBLIC_* and NODE_ENV variables (build-time).
# All other secrets (private keys, API secrets, DB passwords) are pulled at
# runtime from AWS Secrets Manager (secret: afridialect/production/env).
#
# Quick start:
#   1. cp .env.local.example .env.local
#   2. Fill in NEXT_PUBLIC_* values and NODE_ENV only
#   3. Ensure AWS credentials are set (env vars or ~/.aws/credentials)
#   4. npm run dev  — secrets loader fetches the rest from AWS automatically
#
# To run fully offline (no AWS):
#   Copy the full set of variables from .env.local.backup into .env.local
#   (the secrets loader always checks process.env first — no AWS call needed)
#
# PRODUCTION / CI
# ---------------
# Set NEXT_PUBLIC_* in your deployment environment (Vercel env vars / CI).
# AWS credentials or IAM role must be present for runtime secret access.
# NEVER commit real secret values to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS — Credentials & Configuration
# Required for KMS key operations and Secrets Manager access.
# In production use an IAM role instead of static credentials.
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# AWS KMS platform guardian key (shared key for ThresholdKey 2-of-2)
AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/...

# AWS Secrets Manager — secret name holding all app secrets
# Default: afridialect/production/env
# AWS_SECRET_ID=afridialect/production/env

# Cache TTL for secrets fetched from AWS (milliseconds). Default: 300000 (5 min)
# SECRETS_CACHE_TTL_MS=300000

# -----------------------------------------------------------------------------
# Supabase — Database & Auth
# NEXT_PUBLIC_* values are safe to expose to the browser.
# SUPABASE_SECRET_KEY is the service-role key — server-side only.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SECRET_KEY=eyJ...

# Direct Postgres URL (for migrations / scripts only — not used at runtime)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Hedera Hashgraph — Testnet / Mainnet
# HEDERA_OPERATOR_PRIVATE_KEY is sensitive — loaded via secrets loader.
# -----------------------------------------------------------------------------
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ACCOUNT_ID=0.0.12345
HEDERA_OPERATOR_PRIVATE_KEY=302e...
HEDERA_TREASURY_ACCOUNT_ID=0.0.12345
HEDERA_TREASURY_PRIVATE_KEY=302e...

# NFT token IDs (populated after token creation)
HEDERA_AUDIO_TOKEN_ID=0.0.99999
HEDERA_TRANSCRIPT_TOKEN_ID=0.0.99998
HEDERA_TRANSLATION_TOKEN_ID=0.0.99997

# -----------------------------------------------------------------------------
# Pinata / IPFS
# PINATA_JWT is sensitive — loaded via secrets loader.
# NEXT_PUBLIC_PINATA_GATEWAY is a public gateway URL — safe to expose.
# -----------------------------------------------------------------------------
PINATA_JWT=eyJ...
PINATA_API_KEY=...
PINATA_SECRET_API_KEY=...
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Email
RESEND_API_KEY=re_...
EMAIL_PROVIDER=resend

# -----------------------------------------------------------------------------
# Audio Processing Limits
# -----------------------------------------------------------------------------
MIN_AUDIO_DURATION_SECONDS=30
MAX_AUDIO_DURATION_SECONDS=40
MAX_AUDIO_FILE_SIZE_MB=50
SUPPORTED_AUDIO_FORMATS=mp3,wav,m4a,ogg

# -----------------------------------------------------------------------------
# Task & Pricing Configuration
# -----------------------------------------------------------------------------
TASK_CLAIM_TIMEOUT_HOURS=24
PRICE_PER_AUDIO_SAMPLE=0.50
PRICE_PER_TRANSCRIPT_SAMPLE=0.50
PRICE_PER_TRANSLATION_SAMPLE=0.50
QC_REVIEW_PAYOUT_USD=1.00
DATASET_EXPORT_TTL_HOURS=24

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_AUDIO_UPLOAD=true
ENABLE_MARKETPLACE=true
ENABLE_NFT_MINTING=false

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE=60
ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Observability (Optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=info
DEBUG_MODE=false
ENABLE_QUERY_LOGGING=false
