{
  "name": "afridialect",
  "version": "1.0.0",
  "description": "Afridialect.ai - A web platform and marketplace for creating and purchasing high-quality speech datasets in African local dialects",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "test:db": "node scripts/test-database.js",
    "test:auth": "node scripts/test-auth.js",
    "test:hedera": "./scripts/test-hedera-config.sh",
    "hedera:activate-accounts": "node scripts/activate-hedera-accounts.js",
    "db:setup": "echo '⚠️  Please run SQL files manually in Supabase Dashboard. See docs/DATABASE_SETUP.md'"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.995.0",
    "@hashgraph/sdk": "^2.80.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "20.17.6",
    "@types/react": "19.0.6",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.6",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "tailwindcss": "3.4.15",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
