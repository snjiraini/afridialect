# Afridialect.ai Environment Configuration
# Copy this file to .env.local and fill in the values

# ===========================================
# Next.js Configuration
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ===========================================
# Supabase Configuration
# ===========================================
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable Key (client-side, safe to expose)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Secret API Key (server-side only, never expose to client)
SUPABASE_SECRET_KEY=your-secret-api-key-here

NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Database (for direct connections if needed)
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# ===========================================
# AWS KMS Configuration (for Hedera key generation)
# ===========================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_KMS_KEY_ID=your-kms-key-id

# ===========================================
# Hedera Configuration
# ===========================================
# Network: testnet or mainnet
HEDERA_NETWORK=testnet

# Treasury Account (main platform account)
HEDERA_TREASURY_ACCOUNT_ID=0.0.xxxxx
HEDERA_TREASURY_PRIVATE_KEY=your-private-key-here

# Operator Account (for transactions)
HEDERA_OPERATOR_ACCOUNT_ID=0.0.xxxxx
HEDERA_OPERATOR_PRIVATE_KEY=your-private-key-here

# NFT Collection IDs (will be created during setup)
HEDERA_AUDIO_TOKEN_ID=
HEDERA_TRANSCRIPT_TOKEN_ID=
HEDERA_TRANSLATION_TOKEN_ID=

# ===========================================
# Pinata (IPFS) Configuration
# ===========================================
# Get these from: https://app.pinata.cloud/keys
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_API_KEY=your-pinata-secret-key
PINATA_JWT=your-pinata-jwt

# Optional: Custom gateway
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# ===========================================
# Email Configuration (for notifications)
# ===========================================
# Options: resend, sendgrid, smtp
EMAIL_PROVIDER=resend

# Resend (recommended)
RESEND_API_KEY=re_your-api-key

# OR SendGrid
# SENDGRID_API_KEY=SG.your-api-key

# OR SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-username
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@afridialect.ai

# ===========================================
# Application Configuration
# ===========================================
# Pricing (in USD, converted to HBAR)
PRICE_PER_AUDIO_SAMPLE=0.50
PRICE_PER_TRANSCRIPT_SAMPLE=0.50
PRICE_PER_TRANSLATION_SAMPLE=0.50

# Contributor Payouts
QC_REVIEW_PAYOUT_USD=1.00

# Task Timeouts
TASK_CLAIM_TIMEOUT_HOURS=24

# Audio Configuration
MIN_AUDIO_DURATION_SECONDS=30
MAX_AUDIO_DURATION_SECONDS=40
MAX_AUDIO_FILE_SIZE_MB=50
SUPPORTED_AUDIO_FORMATS=mp3,wav,m4a,ogg

# Dataset Export
DATASET_EXPORT_TTL_HOURS=24

# ===========================================
# Feature Flags
# ===========================================
ENABLE_AUDIO_UPLOAD=true
ENABLE_MARKETPLACE=false
ENABLE_NFT_MINTING=false

# ===========================================
# Monitoring & Analytics (Optional)
# ===========================================
# Sentry
NEXT_PUBLIC_SENTRY_DSN=

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ===========================================
# Development & Debug
# ===========================================
DEBUG_MODE=false
LOG_LEVEL=info
ENABLE_QUERY_LOGGING=false

# ===========================================
# Security
# ===========================================
# Secret for signing/encryption (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000
